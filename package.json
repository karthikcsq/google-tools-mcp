{
  "name": "google-tools-mcp",
  "version": "1.0.20",
  "description": "Combined Google Workspace MCP server (Drive, Docs, Sheets, Gmail) with lazy-loaded tool categories",
  "type": "module",
  "bin": {
    "google-tools-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "google",
    "gdrive",
    "gmail",
    "sheets",
    "docs"
  ],
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --coverage"
  },
  "license": "MIT",
  "dependencies": {
    "fastmcp": "^3.24.0",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.4.0",
    "mammoth": "^1.9.0",
    "markdown-it": "^14.1.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0"
  }
}
